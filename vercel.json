{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/exercises", "destination": "/exercises.html" },
    { "source": "/classes", "destination": "/classes.html" },
    { "source": "/guides", "destination": "/guides.html" },
    { "source": "/services-dev", "destination": "/services-dev.html" }
  ]
}
